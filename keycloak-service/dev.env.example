KEYCLOAK_REALM_ID=backend-auth-dev
KEYCLOAK_REALM_NAME=backend-auth-dev
KEYCLOAK_REALM_DISPLAY_NAME=Backend Auth Dev
KEYCLOAK_SSL_REQUIRED=NONE
KEYCLOAK_REGISTRATION_ALLOWED=true
KEYCLOAK_LOGIN_WITH_EMAIL_ALLOWED=true
KEYCLOAK_RESET_PASSWORD_ALLOWED=true
KEYCLOAK_REMEMBER_ME=true
KEYCLOAK_VERIFY_EMAIL=false
KEYCLOAK_BACKEND_CLIENT_ID=backend-auth-client
KEYCLOAK_BACKEND_CLIENT_NAME=Backend Auth Client
KEYCLOAK_BACKEND_STANDARD_FLOW_ENABLED=true
KEYCLOAK_BACKEND_DIRECT_ACCESS_GRANTS_ENABLED=true
KEYCLOAK_FRONTEND_CLIENT_ID=frontend-admin-auth-client
KEYCLOAK_FRONTEND_CLIENT_NAME=Frontend Admin Auth Client
KEYCLOAK_FRONTEND_ROOT_URL=http://localhost:5173
KEYCLOAK_FRONTEND_BASE_URL=http://localhost:5173
KEYCLOAK_FRONTEND_REDIRECT_URIS_JSON=["http://localhost:5173/*","http://127.0.0.1:5173/*","http://localhost:4173/*","http://127.0.0.1:4173/*"]
KEYCLOAK_FRONTEND_WEB_ORIGINS_JSON=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173","http://127.0.0.1:4173"]
KEYCLOAK_USERS_FILE=/opt/keycloak/dev/dev-users.json
