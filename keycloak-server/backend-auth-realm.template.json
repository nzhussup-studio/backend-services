{
  "id": "__REALM_ID__",
  "realm": "__REALM_NAME__",
  "displayName": "__REALM_DISPLAY_NAME__",
  "enabled": true,
  "sslRequired": "__SSL_REQUIRED__",
  "registrationAllowed": "__REGISTRATION_ALLOWED__",
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": "__LOGIN_WITH_EMAIL_ALLOWED__",
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": "__RESET_PASSWORD_ALLOWED__",
  "rememberMe": "__REMEMBER_ME__",
  "verifyEmail": "__VERIFY_EMAIL__",
  "defaultRoles": [
    "ROLE_USER"
  ],
  "roles": {
    "realm": [
      {
        "name": "ROLE_ADMIN",
        "description": "Administrative access for the platform."
      },
      {
        "name": "ROLE_USER",
        "description": "Default authenticated user role."
      }
    ]
  },
  "clients": [
    {
      "clientId": "__BACKEND_CLIENT_ID__",
      "name": "__BACKEND_CLIENT_NAME__",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "__BACKEND_AUTH_CLIENT_SECRET__",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": "__BACKEND_STANDARD_FLOW_ENABLED__",
      "directAccessGrantsEnabled": "__BACKEND_DIRECT_ACCESS_GRANTS_ENABLED__",
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "__FRONTEND_CLIENT_ID__",
      "name": "__FRONTEND_CLIENT_NAME__",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "rootUrl": "__FRONTEND_ROOT_URL__",
      "baseUrl": "__FRONTEND_BASE_URL__",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "__BACKEND_CLIENT_ID__",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ],
      "redirectUris": "__FRONTEND_REDIRECT_URIS_JSON__",
      "webOrigins": "__FRONTEND_WEB_ORIGINS_JSON__"
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": "__GOOGLE_ENABLED__",
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "__GOOGLE_CLIENT_ID__",
        "clientSecret": "__GOOGLE_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "guiOrder": "1",
        "defaultScope": "openid profile email"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": "__GITHUB_ENABLED__",
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "__GITHUB_CLIENT_ID__",
        "clientSecret": "__GITHUB_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "guiOrder": "2",
        "userInfoUrl": "https://api.github.com/user",
        "authorizationUrl": "https://github.com/login/oauth/authorize",
        "tokenUrl": "https://github.com/login/oauth/access_token"
      }
    }
  ],
  "users": "__USERS_JSON__"
}
